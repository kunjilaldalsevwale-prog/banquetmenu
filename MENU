import { promises as fs } from 'fs';
import path from 'path';

const DATA_FILE = '/tmp/foodhouse_menus.json';

async function loadMenus() {
  try {
    const data = await fs.readFile(DATA_FILE, 'utf8');
    return JSON.parse(data);
  } catch {
    return { restaurant: { categories: [] }, banquet: { categories: [] }, chaat: { categories: [] } };
  }
}

async function saveMenus(menus) {
  await fs.writeFile(DATA_FILE, JSON.stringify(menus), 'utf8');
}

export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') return res.status(200).end();

  // GET — load all menus
  if (req.method === 'GET') {
    const menus = await loadMenus();
    return res.status(200).json(menus);
  }

  // POST — save menus
  if (req.method === 'POST') {
    const { menus } = req.body;
    if (!menus) return res.status(400).json({ error: 'No menu data provided' });
    await saveMenus(menus);
    return res.status(200).json({ success: true });
  }

  return res.status(405).json({ error: 'Method not allowed' });
}
